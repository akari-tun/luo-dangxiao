<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:luo.dangxiao.selfservice.ViewModels"
        xmlns:v="using:luo.dangxiao.selfservice.Views"
        xmlns:lang="clr-namespace:luo.dangxiao.resources.Languages;assembly=luo.dangxiao.resources"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="1024"
        x:Class="luo.dangxiao.selfservice.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        WindowState="Maximized"
        Title="{x:Static lang:LanguageProvider.App_Title}"
        Width="1280" Height="1024">

    <Grid>
        <Image Source="avares://luo.dangxiao.resources/Images/background.png" 
               Stretch="UniformToFill"/>
		<v:HomePageView/>

        <Border Background="{StaticResource WarningBrush}" 
                IsVisible="{Binding IsStartupWarningVisible}"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Margin="24,18,24,0"
                CornerRadius="6"
                Padding="16,10">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <TextBlock Text="{Binding StartupWarningMessage}" 
                           Foreground="{StaticResource TextWhiteBrush}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"/>
                <Button Grid.Column="1"
                        Command="{Binding DismissStartupWarningCommand}"
                        Content="{x:Static lang:LanguageProvider.Button_Close}"
                        MinWidth="92"
                        Padding="16,6"
                        VerticalAlignment="Center"
                        Background="#33FFFFFF"
                        Foreground="{StaticResource TextWhiteBrush}"
                        BorderBrush="#66FFFFFF"
                        BorderThickness="1"/>
            </Grid>
        </Border>
    </Grid>

</Window>
