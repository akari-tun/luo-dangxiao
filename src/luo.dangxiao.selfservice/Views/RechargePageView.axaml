<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:luo.dangxiao.selfservice.ViewModels"
             xmlns:lang="clr-namespace:luo.dangxiao.resources.Languages;assembly=luo.dangxiao.resources"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="700"
             x:Class="luo.dangxiao.selfservice.Views.RechargePageView"
             x:DataType="vm:RechargePageViewModel">

    <Design.DataContext>
        <vm:RechargePageViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.amount-option">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="84"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryRedDarkBrush}"/>
            <Setter Property="FontFamily" Value="SimHei"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style Selector="Button.amount-option.selected">
            <Setter Property="Background" Value="{StaticResource PrimaryRedDarkBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,130">
        <Grid>
            <Image Source="avares://luo.dangxiao.resources/Images/bg.png" Stretch="Fill"/>

            <Border Margin="45,30,45,30"
                    CornerRadius="7">
                <Grid RowDefinitions="48,430,*">
                    <StackPanel Grid.Row="0" Margin="32,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="avares://luo.dangxiao.resources/Images/payment.png"
                               Width="48"
                               Height="48"
                               Margin="0,0,20,0"/>
                        <TextBlock FontFamily="SimHei"
                                   FontSize="45"
                                   Foreground="{StaticResource PrimaryRedBrush}"
                                   Text="{Binding PageTitle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Top"
                            Background="Transparent">
                        <ContentControl HorizontalAlignment="Stretch"
                                        VerticalAlignment="Top"
                                        Content="{Binding UserInfoModuleContent}"/>
                    </Border>

                    <Border Grid.Row="2"
                            Margin="45,10,45,0"
                            Padding="26,20"
                            Background="#F4F4EE"
                            CornerRadius="8">
                        <Grid>
                            <!-- Confirm State -->
                            <StackPanel Spacing="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        IsVisible="{Binding IsConfirmState}">
                                <TextBlock Text="{Binding AmountSelectionTitle}"
                                           FontFamily="SimHei"
                                           FontSize="34"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>

                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center" ItemWidth="240" ItemHeight="90">
                                    <Button Classes="amount-option"
                                            Classes.selected="{Binding IsAmount20Selected}"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="20"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount20Text}"/>
                                    </Button>
                                    <Button Classes="amount-option"
                                            Classes.selected="{Binding IsAmount50Selected}"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="50"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount50Text}"/>
                                    </Button>
                                    <Button Classes="amount-option"
                                            Classes.selected="{Binding IsAmount100Selected}"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="100"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount100Text}"/>
                                    </Button>
                                    <Button Classes="amount-option"
                                            Classes.selected="{Binding IsAmount200Selected}"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="200"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount200Text}"/>
                                    </Button>
                                    <Button Classes="amount-option"
                                            Classes.selected="{Binding IsAmount500Selected}"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="500"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount500Text}"/>
                                    </Button>
                                </WrapPanel>

                                <TextBlock Text="{Binding StatusMessage}"
                                           FontFamily="SimHei"
                                           FontSize="28"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- QR Code State -->
                            <Grid IsVisible="{Binding IsQRCodeState}" ColumnDefinitions="*,350" HorizontalAlignment="Stretch">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding StatusMessage}"
                                               FontFamily="SimHei"
                                               FontSize="36"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryRedDarkBrush}"
                                               HorizontalAlignment="Center"/>

                                    <TextBlock Text="ÇëÔÚĘÖ»úÉĎÍęłÉÖ§¸¶˛˘·µ»Ř±ľ»úČ·ČĎˇŁ"
                                               FontFamily="SimHei"
                                               FontSize="26"
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="300" Height="300" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Image Source="{Binding QrCodeImage}" Stretch="Uniform"/>
                                    </Border>

                                    <TextBlock Text="ÇëĘąÓĂÎ˘ĐĹ/Ö§¸¶±¦É¨Ăč¶ţÎ¬Âë"
                                               FontFamily="SimHei"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.Styles>
                <StyleInclude Source="avares://luo.dangxiao.resources/Styles/ButtonStyles.axaml"/>
            </Grid.Styles>

            <Button Command="{Binding BackCommand}"
                    Width="322"
                    Height="95"
                    FontSize="40"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="avares://luo.dangxiao.resources/Images/back_icon.png"
                           Width="48"
                           Height="48"
                           Margin="0,0,20,0"/>
                    <TextBlock Text="{x:Static lang:LanguageProvider.Button_Back}"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
