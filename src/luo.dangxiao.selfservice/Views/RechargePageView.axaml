<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:luo.dangxiao.selfservice.ViewModels"
             xmlns:lang="clr-namespace:luo.dangxiao.resources.Languages;assembly=luo.dangxiao.resources"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="700"
             x:Class="luo.dangxiao.selfservice.Views.RechargePageView"
             x:DataType="vm:RechargePageViewModel">

    <Design.DataContext>
        <vm:RechargePageViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="AmountOptionBackgroundBrush" StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Offset="0" Color="#ff1400"/>
                <GradientStop Offset="1" Color="#ca0000"/>
            </LinearGradientBrush>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="Button.amount-option">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="84"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource AmountOptionBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextWhiteBrush}"/>
            <Setter Property="FontFamily" Value="SimHei"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextWhiteBrush}"/>
            </Style>

            <Style Selector="^:pressed /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Foreground" Value="{DynamicResource TextWhiteBrush}"/>
            </Style>

            <Style Selector="^:disabled /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource ButtonDisabledBackgroundColor}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextWhiteBrush}"/>
            </Style>
        </Style>
        <Style Selector="TextBlock.page-title">
            <Setter Property="FontFamily" Value="SimHei"/>
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,130">
        <Image Grid.Row="0" Source="avares://luo.dangxiao.resources/Images/bg.png" Stretch="Fill"/>

        <Border Grid.Row="0" Margin="45,30,45,30"
                CornerRadius="7">
		    <Grid RowDefinitions="48,*">
                    <StackPanel Grid.Row="0" Margin="32,0,0,0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="avares://luo.dangxiao.resources/Images/payment.png"
                               Width="48"
                               Height="48"
                               Margin="0,0,20,0"/>
                        <TextBlock FontFamily="SimHei"
                                   FontSize="45"
                                   Foreground="{StaticResource PrimaryRedBrush}"
                                   Text="{Binding PageTitle}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Confirm State -->
                    <Grid Grid.Row="1" IsVisible="{Binding IsConfirmState}" RowDefinitions="Auto,96,*">
                        <Border Grid.Row="0"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                IsVisible="{Binding IsConfirmState}">
                            <ContentControl HorizontalAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Content="{Binding UserInfoModuleContent}"/>
                        </Border>

                        <Border Grid.Row="1"
                                Padding="30,0,30,0"
                                CornerRadius="7"
                                VerticalAlignment="Top">
                            <StackPanel Spacing="18" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Border Width="8" Height="32" Background="{StaticResource PrimaryRedDarkBrush}" CornerRadius="4"/>
                                    <TextBlock Text="{Binding AmountSelectionTitle}" Classes="page-title"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <Button Classes="amount-option"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="20"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount20Text}"/>
                                    </Button>
                                    <Button Classes="amount-option"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="50"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount50Text}"/>
                                    </Button>
                                    <Button Classes="amount-option"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="100"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount100Text}"/>
                                    </Button>
                                    <Button Classes="amount-option"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="200"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount200Text}"/>
                                    </Button>
                                    <Button Classes="amount-option"
                                            Command="{Binding RechargeCommand}"
                                            CommandParameter="500"
                                            IsEnabled="{Binding CanRecharge}">
                                        <TextBlock Text="{Binding Amount500Text}"/>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- QR Code State -->
                    <Grid Grid.Row="1" Margin="32,64,0,0" IsVisible="{Binding IsQRCodeState}" ColumnDefinitions="Auto,128,*" HorizontalAlignment="Stretch">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontFamily="SimHei"
                                       FontSize="48"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryRedDarkBrush}"/>
                        
                            <TextBlock Text="{x:Static lang:LanguageProvider.SelfService_Recharge_QRCode_Instruction}"
                                       FontFamily="SimHei"
                                       FontSize="26"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <Border Width="300" Height="300" Background="White" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image Source="{Binding QrCodeImage}" Stretch="Uniform"/>
                            </Border>
                        
                            <TextBlock Text="{x:Static lang:LanguageProvider.SelfService_Recharge_QRCode_ScanHint}"
                                       FontFamily="SimHei"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0"/>
                        </StackPanel>
                    </Grid>
           </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.Styles>
                <StyleInclude Source="avares://luo.dangxiao.resources/Styles/ButtonStyles.axaml"/>
            </Grid.Styles>

            <Button Command="{Binding BackCommand}"
                    Width="322"
                    Height="95"
                    FontSize="40"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="avares://luo.dangxiao.resources/Images/back_icon.png"
                           Width="48"
                           Height="48"
                           Margin="0,0,20,0"/>
                    <TextBlock Text="{x:Static lang:LanguageProvider.Button_Back}"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</UserControl>
